# -*- mode: ruby -*-
# vi: set ft=ruby :

# ---------------------------------------------------------------------------
# Configuration constants
# ---------------------------------------------------------------------------
BOX    = "generic/alpine319"
MEMORY = 2048
CPUS   = 2

LOGIN            = "lepereir"
SERVER           = "#{LOGIN}S"       # K3s server node
SERVER_WORKER    = "#{LOGIN}SW"      # K3s agent node
SERVER_IP        = "192.168.56.110"
SERVER_WORKER_IP = "192.168.56.111"

Vagrant.configure("2") do |config|
  # Base box shared by both machines.
  config.vm.box = BOX
  config.vm.box_check_update = false

  # Shared setup run on every node (prerequisites + kubectl alias).
  # Global provisioners run before the per-machine ones below.
  config.vm.provision "shell", path: "scripts/common.sh"

  # -------------------------------------------------------------------------
  # Server / K3s server node
  # -------------------------------------------------------------------------
  config.vm.define SERVER do |server|
    server.vm.hostname = SERVER
    server.vm.network "private_network", ip: SERVER_IP

    server.vm.provider "virtualbox" do |vb|
      vb.name   = SERVER
      vb.memory = MEMORY
      vb.cpus   = CPUS
      # Faster CPU scheduling for Linux guests.
      vb.customize ["modifyvm", :id, "--paravirtprovider", "kvm"]
    end

    # Install and start K3s in server mode.
    server.vm.provision "shell", path: "scripts/server.sh"
  end

  # -------------------------------------------------------------------------
  # Worker / K3s agent node
  # -------------------------------------------------------------------------
  config.vm.define SERVER_WORKER do |worker|
    worker.vm.hostname = SERVER_WORKER
    worker.vm.network "private_network", ip: SERVER_WORKER_IP

    worker.vm.provider "virtualbox" do |vb|
      vb.name   = SERVER_WORKER
      vb.memory = MEMORY
      vb.cpus   = CPUS
      # Faster CPU scheduling for Linux guests.
      vb.customize ["modifyvm", :id, "--paravirtprovider", "kvm"]
    end

    # Install and start K3s in agent mode (joins the server).
    worker.vm.provision "shell", path: "scripts/server-worker.sh"
  end
end
